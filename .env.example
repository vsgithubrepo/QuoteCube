# ============================================================
# QuoteCube — Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to GitHub
# ============================================================

# ------------------------------------------------------------
# Supabase (Frontend + Backend)
# Get from: supabase.com → your project → Settings → API Keys
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...your-anon-public-key

# ------------------------------------------------------------
# Backend API (Node.js on Railway)
# Used by the React frontend to call the pricing engine
# ------------------------------------------------------------
VITE_BACKEND_URL=https://quotecube-api.railway.app

# ------------------------------------------------------------
# Backend-only variables (set in Railway environment, not here)
# These are never exposed to the browser
# ------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...your-service-role-key
JWT_SECRET=your-random-jwt-secret-min-32-chars
PORT=3000

# ------------------------------------------------------------
# Email (Resend API — resend.com)
# Free tier: 100 emails/day
# Get from: resend.com → API Keys
# ------------------------------------------------------------
RESEND_API_KEY=re_...your-resend-api-key
EMAIL_FROM=quotes@etechcube.com
EMAIL_FROM_NAME=eTechCube QuoteCube

# ------------------------------------------------------------
# App config
# ------------------------------------------------------------
NODE_ENV=development
APP_NAME=QuoteCube
APP_URL=https://quotecube.vercel.app
